// BinaCore Construction Project Management Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  floorsCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors    Floor[]
  reports   Report[]
  tasks     CESTask[]
  activities Activity[]
  issues    Issue[]
}

model Floor {
  id          String      @id @default(cuid())
  floorNumber Int
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities Activity[]
}

model Activity {
  id          String   @id @default(cuid())
  floorId     String
  type        String   // "reinforcement" or "concrete"
  status      String   @default("not_started") // "not_started", "in_progress", "completed"
  dateTime    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floor      Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  project    Project   @relation(fields: [floorId], references: [id], onDelete: Cascade)
}

model CESTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  type        String   // "CET" or "CES"
  description String?
  progress    Int      @default(0) // 0-100
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // "PV_Visite" or "PV_Constat"
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id          String   @id @default(cuid())
  language    String   @default("en") // "en" or "fr" or "ar"
  theme       String   @default("light") // "light" or "dark"
  notifications Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Issue {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String   @default("other") // "structural", "safety", "material", "quality", "other"
  severity    String   @default("medium") // "low", "medium", "high", "critical"
  status      String   @default("open") // "open", "in_progress", "resolved"
  floor       String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}